-- Teleport Tab - Section & Advanced Buttons
TeleportTab:CreateSection("🌎 Quick Teleports")
local tpSpots = {
    ["Camp"] = Vector3.new(100, 5, -100),
    ["Stronghold"] = Vector3.new(200, 10, 50),
    ["Fairy"] = Vector3.new(150, 10, 120),
    ["Wolf"] = Vector3.new(-55, 6, 130),
    ["Bunny"] = Vector3.new(80, 7, -123),
    ["Alpha Wolf"] = Vector3.new(-140, 5, 173),
    ["Bear"] = Vector3.new(432, 5, 22),
    ["Kids 1"] = Vector3.new(203, 3, 67),
    ["Kids 2"] = Vector3.new(220, 3, 70),
    ["Kids 3"] = Vector3.new(225, 3, 65),
    ["Kids 4"] = Vector3.new(210, 3, 69)
    -- ADD pa kung gusto mo
}
TeleportTab:CreateDropdown({
    Name = "Quick Teleport",
    Options = {"Camp", "Stronghold", "Fairy", "Wolf", "Bunny", "Alpha Wolf", "Bear", "Kids 1", "Kids 2", "Kids 3", "Kids 4"},
    CurrentOption = "Camp",
    Callback = function(spot)
        local pos = tpSpots[spot]
        if pos then
            game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(pos)
            Rayfield:Notify({ Title = "Teleported!", Content = "You went to: "..spot, Duration = 3 })
        end
    end
})

TeleportTab:CreateInput({
    Name = "Custom Teleport",
    PlaceholderText = "X, Y, Z",
    RemoveTextAfterFocusLost = true,
    Callback = function(Input)
        local coords = {}
        for i in string.gmatch(Input, "[^,%s]+") do table.insert(coords, tonumber(i)) end
        if #coords == 3 then
            game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(coords[1], coords[2], coords[3])
            Rayfield:Notify({ Title = "Teleported!", Content = "You went to: "..Input, Duration = 3 })
        else
            Rayfield:Notify({ Title = "Invalid Input", Content = "Format: 100, 7, 45", Duration = 3 })
        end
    end
})


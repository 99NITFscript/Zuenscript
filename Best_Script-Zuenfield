TeleportTab:CreateSection("🌎 Quick Teleports")

local tpSpots = {
    ["Camp"] = Vector3.new(100, 5, -100),
    ["Stronghold"] = Vector3.new(200, 10, 50),
    ["Fairy"] = Vector3.new(150, 10, 120),
    ["Wolf"] = Vector3.new(-55, 6, 130),
    ["Bunny"] = Vector3.new(80, 7, -123),
    ["Alpha Wolf"] = Vector3.new(-140, 5, 173),
    ["Bear"] = Vector3.new(432, 5, 22),
    ["Kids 1"] = Vector3.new(203, 3, 67),
    ["Kids 2"] = Vector3.new(220, 3, 70),
    ["Kids 3"] = Vector3.new(225, 3, 65),
    ["Kids 4"] = Vector3.new(210, 3, 69)
}

TeleportTab:CreateDropdown({
    Name = "Quick Teleport",
    Options = {"Camp", "Stronghold", "Fairy", "Wolf", "Bunny", "Alpha Wolf", "Bear", "Kids 1", "Kids 2", "Kids 3", "Kids 4"},
    CurrentOption = "Camp",
    Callback = function(spot)
        local pos = tpSpots[spot]
        if teleportPlayer(pos.X, pos.Y, pos.Z) then
            safeNotify("Teleported!", "You went to: " .. spot)
        else
            safeNotify("Error", "Cannot teleport!")
        end
    end
})

TeleportTab:CreateButton({
    Name = "Teleport to Camp",
    Callback = function()
        if teleportPlayer(tpSpots["Camp"].X, tpSpots["Camp"].Y, tpSpots["Camp"].Z) then
            safeNotify("Teleported!", "Direct to Camp.")
        end
    end
})

TeleportTab:CreateSection("🎯 Custom Teleport")
TeleportTab:CreateInput({
    Name = "Custom Teleport",
    PlaceholderText = "X, Y, Z",
    RemoveTextAfterFocusLost = true,
    Callback = function(Input)
        local coords = {}
        for i in string.gmatch(Input, "[^,%s]+") do
            table.insert(coords, tonumber(i))
        end
        if #coords == 3 then
            if teleportPlayer(coords[1], coords[2], coords[3]) then
                safeNotify("Teleported!", "You went to: " .. Input)
            else
                safeNotify("Error", "Cannot teleport!")
            end
        else
            safeNotify("Invalid Input", "Format: 100, 7, 45")
        end
    end
})

